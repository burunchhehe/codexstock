{
  "mcpServers": {
    "codexstock": {
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& (Join-Path $env:USERPROFILE 'CodexStock\\run_mcp_server.ps1')"
      ],
      "env": {
        "CODEXSTOCK_BASE_URL": "http://127.0.0.1:8765"
      }
    }
  }
}
