# CodexStock local configuration example
# Copy this file to .env.local and fill in your own credentials.
# Never commit .env.local or real credentials.

# Private runtime folders
CODEXSTOCK_USER_DATA_DIR=
CODEXSTOCK_CONFIG_DIR=

# Safety defaults
LIVE_TRADING=false
KIS_USE_MOCK=true
KIS_READONLY=true
KIS_MODE=mock

# Korea Investment & Securities Open API
KIS_BASE_URL=
KIS_QUOTE_THROTTLE_MS=50
KIS_MOCK_APP_KEY=
KIS_MOCK_APP_SECRET=
KIS_MOCK_ACCOUNT_NO=
KIS_MOCK_ACNT_PRDT_CD=01
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_USER_ID=
KIS_WATCHLIST_AUTO_SYNC=true

# OpenDART / KRX / macro data
DART_API_KEY=
DART_LOOKBACK_DAYS=7
CACHE_TTL_DART_SEC=1800
CACHE_TTL_KIS_SEC=120
BOK_ECOS_API_KEY=
ECOS_API_KEY=
ECOS_LANGUAGE=kr
FRED_API_KEY=
KRX_API_KEY=
KRX_BASE_URL=
CACHE_TTL_KRX_SEC=1800
CACHE_TTL_ECOS_SEC=1800
CACHE_TTL_FRED_SEC=1800

# AI model endpoints
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Telegram reporting
TELEGRAM_ENABLED=false
TELEGRAM_DRY_RUN=true
TELEGRAM_STUB=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
